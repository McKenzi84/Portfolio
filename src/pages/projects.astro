---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/posts.css";
import "../styles/photos.css";
// import { Markdown } from '@astro/types'; // typ opcjonalny

// Pobieramy wszystkie pliki .md w folderze posts
const postFiles = import.meta.glob("../pages/posts/*.md", { eager: true });

// Zamieniamy na tablicę postów
const posts = Object.values(postFiles)
  .map((post: any) => (post.frontmatter ? post : null))
  .filter(Boolean)
  .map((post) => ({
    title: post.frontmatter.title,
    description: post.frontmatter.description,
    date: new Date(post.frontmatter.pubDate).toISOString().split("T")[0],
    author: post.frontmatter.author,
    content: post.default, // to jest komponent Astro
  }))
  // sortujemy po dacie (opcjonalnie)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<BaseLayout pageTitle="Blog">
  <!-- <h1>Blog</h1> -->

  <div class="posts">
    {
      posts.map((post) => (
        <article class="post">
          <h2>{post.title}</h2>
          <h3>{post.description}</h3>
          <div class="content">
            <post.content />
          </div>
          <p class="date"> {post.date}</p>
          <p>{post.author}</p>
        </article>
      ))
    }
  </div>
</BaseLayout>
