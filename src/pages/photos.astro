---
import BaseLayout from "../layouts/BaseLayout.astro";
import type { ImageMetadata } from "astro";
import "../styles/photos.css";

/* Jawnie określamy typ */
const images = Object.values(
  import.meta.glob<{ default: ImageMetadata }>(
    "../assets/photos/*.{jpg,jpeg,png,webp}",
    { eager: true }
  )
);
---

<BaseLayout pageTitle="Photos">
  <h1>Galeria zdjęć</h1>

  <div class="photo-grid">
    {
      images.map((img) => (
        <img
          src={img.default.src}
          width={img.default.width}
          height={img.default.height}
          alt="Photo"
          loading="lazy"
        />
      ))
    }
  </div>

  <!-- Lightbox overlay -->
  <div id="lightbox" class="lightbox" aria-hidden="true">
    <button class="lightbox-close" aria-label="Close">×</button>
    <img class="lightbox-img" src="" alt="Enlarged photo" />
    <div class="lightbox-caption" aria-hidden="true"></div>
  </div>

  <script>
    import "../scripts/photos.js";
  </script>
</BaseLayout>
